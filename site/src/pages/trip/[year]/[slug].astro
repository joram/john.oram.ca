---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Sidebar from '../../../components/Sidebar.astro';

export async function getStaticPaths() {
  const entries = await getCollection('trip_reports');
  return entries.map((entry) => {
    // entry.id is like "2023-Rainier.md"
    const base = entry.id.replace(/\.md$/, '');
    const dashIdx = base.indexOf('-');
    const year = base.slice(0, dashIdx);
    const slug = base.slice(dashIdx + 1);
    return { params: { year, slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const title = entry.data.title ?? entry.id.replace(/\.md$/, '').replace(/^\d{4}-/, '').replace(/_/g, ' ');
---

<Layout title={`${title} — John Oram`}>
  <Sidebar slot="sidebar" />
  <div class="max-w-3xl mx-auto">
    <div class="bg-[#3d3e3f] rounded-lg p-6 markdown-body">
      <Content />
    </div>
  </div>
</Layout>

<style is:global>
  .markdown-body h1 { @apply text-3xl font-bold text-white mb-4 mt-2; }
  .markdown-body h2 { @apply text-2xl font-bold text-white mb-3 mt-6; }
  .markdown-body h3 { @apply text-xl font-semibold text-white mb-2 mt-4; }
  .markdown-body p  { @apply text-white/80 mb-4 leading-relaxed; }
  .markdown-body ul { @apply list-disc pl-6 mb-4 space-y-1 text-white/80; }
  .markdown-body ol { @apply list-decimal pl-6 mb-4 space-y-1 text-white/80; }
  .markdown-body a  { @apply text-sky-400 hover:underline; }
  .markdown-body img { @apply max-w-full h-auto rounded my-4 mx-auto block; }
  .markdown-body table { @apply w-full border-collapse mb-4; }
  .markdown-body th { @apply border-b-2 border-white/30 px-3 py-2 text-left text-white; }
  .markdown-body td { @apply border-b border-white/15 px-3 py-2 text-white/80; }
  .markdown-body code { @apply bg-black/30 px-1 rounded text-sm font-mono; }
  .markdown-body pre  { @apply bg-black/30 p-4 rounded mb-4 overflow-x-auto; }
  .markdown-body pre code { @apply bg-transparent p-0; }
  .markdown-body hr { @apply border-white/15 my-6; }
  .markdown-body blockquote { @apply border-l-4 border-white/30 pl-4 italic text-white/60 my-4; }
</style>
